# Project command policy.

prefix_rule(
    pattern = ["git", "config"],
    decision = "forbidden",
    justification = "Git configuration must not be changed automatically.",
    match = ["git config user.email dev@example.com"],
)

prefix_rule(
    pattern = ["aws"],
    decision = "forbidden",
    justification = "AWS mutations must not be performed automatically.",
    match = ["aws s3 rm s3://example --recursive"],
)

prefix_rule(
    pattern = ["cdk", "deploy"],
    decision = "forbidden",
    justification = "Cloud deployment must be performed manually after review.",
    match = ["cdk deploy"],
)

prefix_rule(
    pattern = ["cdk", "destroy"],
    decision = "forbidden",
    justification = "Cloud destruction must never be automated by Codex.",
    match = ["cdk destroy"],
)
