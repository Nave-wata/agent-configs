{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".claude/CLAUDE.md"
  ],
  "share": "disabled",
  "autoupdate": false,
  "small_model": "ollama/ornith",
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "sudo*": "deny",
      "git config*": "deny",
      "brew install*": "deny",
      "chmod 777*": "deny",
      "aws*": "deny",
      "cdk deploy*": "deny",
      "cdk destroy*": "deny",
      "claude*": "deny",
      "codex*": "deny",
      "gemini*": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "id_rsa*": "deny",
      "id_ed25519*": "deny",
      "*.key": "deny",
      "*.pem": "deny"
    },
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "id_rsa*": "deny",
      "id_ed25519*": "deny",
      "*.key": "deny",
      "*.pem": "deny"
    }
  },
  "model": "ollama/ornith",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://host.docker.internal:12711/v1",
        "apiKey": "llama"
      },
      "models": {
        "ornith": {
          "name": "Ornith 1.0 35B",
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "reasoning": true,
          "tool_call": true
        }
      }
    }
  },
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": ["npx", "-y", "@brave/brave-search-mcp-server"],
      "enabled": true,
      "environment": {
        "BRAVE_API_KEY": "<BRAVE_API_KEY>"
      }
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "environment": {
        "CONTEXT7_API_KEY": "<CONTEXT7_API_KEY>"
      }
    }
  }
}
