#!/usr/bin/env bash
#
# agent-setup — agent-configs のエージェント設定を対象プロジェクトへ展開する。
#
#   使い方:
#     agent-setup                      # 全ツールをカレントディレクトリへ展開
#     agent-setup <path>               # 指定ディレクトリへ展開
#     agent-setup --claude             # claude のみ展開
#     agent-setup --claude --codex <path>  # 複数指定 + 展開先指定
#     agent-setup -y                   # 確認プロンプトを出さずに展開
#     agent-setup --no-update          # 配布元の自動更新（git pull）を行わない
#
#   方式:
#     リポジトリ内の各ソースディレクトリ（claude/ codex/ opencode/）を、
#     対象プロジェクトの .claude/ .codex/ .opencode/ へコピーする。
#     スクリプト自身の位置からリポルートを解決するため、リポをどこに
#     置いても動作する（ディレクトリ非依存）。
#
#   ツール選択:
#     --<ツール名> フラグで展開対象を絞れる。フラグ名は SOURCES から動的に
#     導出するため、SOURCES にツールを足せばフラグも自動で増える。
#     フラグ無指定なら全ツールが対象（従来どおり）。
#     選ばなかったツールの既存展開ファイルには一切触らない。
#
#   配布元の自動更新:
#     展開の前に配布元リポジトリを git pull --ff-only で最新化する（pull し忘れた
#     まま古い設定を配ってしまう事故の防止）。ただしリポジトリの状態を変える操作は
#     fast-forward pull のみに限定し、次の場合は警告してローカルの内容で続行する:
#       - 配布元が git リポジトリでない
#       - 作業ツリーに未コミットの変更がある（正本を main で直接編集する運用のため、
#         編集途中の実行は想定内。stash 等で無理に進めない）
#       - pull 失敗（ネットワーク不通・fast-forward 不可・追跡ブランチなし等）
#     GIT_TERMINAL_PROMPT=0 を付け、認証プロンプトで無限に待つ事故を防ぐ。
#     --no-update で更新自体をスキップできる。
#
#   更新（マニフェスト方式）:
#     展開したファイル一覧を対象プロジェクトの .agent-configs-manifest に記録する。
#     再実行時は「前回配ったが今回ソースに無いファイル」だけを削除し、
#     マニフェストに無いファイル（プロジェクト固有のファイル）は一切触らない。
#     ツールを絞った場合、削除判定は選択ツール配下の行だけに限定し、
#     非選択ツールのマニフェスト行はそのまま持ち越す（次回そのツールを
#     選んだときに正しく削除判定できるようにするため）。
#
#   出力:
#     再実行のたびに何が変わったかを可視化する。ファイルごとに
#     追加(+) / 更新(~) / 削除(-) を判定し、ツール別（.claude/.codex/.opencode）に
#     集計したうえで変更ファイルを一覧表示する。無変更のものは表示しない。
#     色は stdout が端末のときだけ付与し、パイプ/リダイレクト時や NO_COLOR
#     設定時は自動で無色にフォールバックする。
#
#   確認:
#     選択ツールの .<name> が展開先に1つでも既にある場合、上記の差分を見せた
#     うえで実行全体につき1回だけ y/N を尋ねる。すべて新規なら無言で展開する
#     （壊す既存物が無いため）。既存でも差分がゼロなら尋ねる意味が無いので出さない。
#     -y / --yes で確認を省略できる。既存があるのに stdin が端末でない
#     （CI・パイプ経由）ときは確認しようがないため、展開せずエラー終了する。
#
#   処理順:
#     確認を挟むため「判定」と「適用」を分離している。まず走査だけを行って
#     追加/更新/削除を算出し（この時点でファイルは一切書き換えない）、差分表示と
#     確認を経てから、コピー・削除・マニフェスト更新をまとめて適用する。
#
set -euo pipefail

# --- リポルート（スクリプト自身の位置基準。symlink 経由で呼ばれても実体を解決） ---
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in
    /*) ;;                      # 絶対パスはそのまま
    *) SOURCE="$DIR/$SOURCE" ;; # 相対 symlink は元ディレクトリ基準で解決
  esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# 配布しうるソースディレクトリ（トップレベル名）。それぞれ .<name> へ展開する。
# ここが「このリポが管理しうる全ツール」の定義であり、--<name> フラグの語彙でもある。
SOURCES="claude codex opencode"

# --- 引数パース（--<ツール名> フラグ / -y / 展開先パス） ---
# SELECTED  … 今回の展開対象。フラグ未指定なら SOURCES 全部にフォールバックする。
# YES       … 1 なら確認プロンプトを省略する。
# NO_UPDATE … 1 なら配布元の自動更新（git pull）を行わない。
SELECTED=""
TARGET_ARG=""
YES=0
NO_UPDATE=0
for arg in "$@"; do
  case "$arg" in
    -y|--yes)
      YES=1
      ;;
    --no-update)
      NO_UPDATE=1
      ;;
    --*)
      name="${arg#--}"
      matched=0
      for src in $SOURCES; do
        if [ "$name" = "$src" ]; then matched=1; break; fi
      done
      if [ "$matched" -eq 0 ]; then
        echo "エラー: 不明なオプション: $arg" >&2
        echo "       指定できるのは以下のいずれかです:" >&2
        for src in $SOURCES; do echo "         --$src" >&2; done
        echo "         -y, --yes" >&2
        echo "         --no-update" >&2
        exit 1
      fi
      # 同じフラグを重ねて渡されても SELECTED が重複しないようにする
      case " $SELECTED " in *" $name "*) ;; *) SELECTED="$SELECTED $name" ;; esac
      ;;
    *)
      if [ -n "$TARGET_ARG" ]; then
        echo "エラー: 展開先を複数指定できません: $TARGET_ARG, $arg" >&2
        exit 1
      fi
      TARGET_ARG="$arg"
      ;;
  esac
done

# フラグが1つも無ければ全ツール展開（従来どおりの挙動）
if [ -z "$SELECTED" ]; then
  SELECTED="$SOURCES"
else
  SELECTED="${SELECTED# }"  # 組み立てで付いた先頭スペースを落とす
fi

# --- 展開先（引数 or カレント） ---
TARGET_ARG="${TARGET_ARG:-$PWD}"
if [ ! -d "$TARGET_ARG" ]; then
  echo "エラー: 展開先ディレクトリが存在しません: $TARGET_ARG" >&2
  exit 1
fi
TARGET="$(cd "$TARGET_ARG" && pwd)"

MANIFEST="$TARGET/.agent-configs-manifest"

# 配布から除外するファイル名（basename 一致）。
#   settings.json … プロジェクトごとに管理される（プロジェクトの git に入る）ため配布しない
#   .gitignore    … 旧・独立リポ時代の名残。展開先の git 管理に干渉させない
# settings.local.json は個人共通のローカル設定として配布する（除外しない）。
EXCLUDE_BASENAMES="settings.json .gitignore"

# --- 色（stdout が端末で、NO_COLOR 未設定のときだけ付与） ---
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_ADD=$'\033[32m'; C_UPD=$'\033[33m'; C_DEL=$'\033[31m'
  C_DIM=$'\033[2m';  C_BOLD=$'\033[1m'; C_RST=$'\033[0m'
else
  C_ADD=''; C_UPD=''; C_DEL=''; C_DIM=''; C_BOLD=''; C_RST=''
fi

# 配布元が1つも見つからない場合は無言終了せず明示的に失敗する
# （symlink 解決ミスなどでリポルートを取り違えていないかの早期検知）。
_found_src=0
for src in $SELECTED; do
  [ -d "$REPO_ROOT/$src" ] && _found_src=1
done
if [ "$_found_src" -eq 0 ]; then
  echo "エラー: 配布元が見つかりません（REPO_ROOT=$REPO_ROOT）。" >&2
  echo "       agent-setup の配置、またはリポルートの解決を確認してください。" >&2
  exit 1
fi

# --- 0. 配布元の自動更新（git pull --ff-only）。失敗しても展開は続行する ---
if [ "$NO_UPDATE" -eq 0 ]; then
  if ! git -C "$REPO_ROOT" rev-parse --git-dir >/dev/null 2>&1; then
    printf '%s警告: 配布元が git リポジトリではないため更新をスキップします。%s\n' "$C_UPD" "$C_RST" >&2
  elif [ -n "$(git -C "$REPO_ROOT" status --porcelain 2>/dev/null)" ]; then
    printf '%s警告: 配布元に未コミットの変更があるため更新をスキップします。%s\n' "$C_UPD" "$C_RST" >&2
  else
    _before="$(git -C "$REPO_ROOT" rev-parse --short HEAD 2>/dev/null || true)"
    if _pull_err="$(GIT_TERMINAL_PROMPT=0 git -C "$REPO_ROOT" pull --ff-only --quiet 2>&1)"; then
      _after="$(git -C "$REPO_ROOT" rev-parse --short HEAD 2>/dev/null || true)"
      if [ -n "$_before" ] && [ "$_before" != "$_after" ]; then
        printf '配布元を更新しました (%s → %s)\n' "$_before" "$_after"
      fi
    else
      printf '%s警告: 配布元の更新に失敗しました。ローカルの内容で続行します。%s\n' "$C_UPD" "$C_RST" >&2
      printf '%s       %s%s\n' "$C_DIM" "$(printf '%s' "$_pull_err" | head -n 1)" "$C_RST" >&2
    fi
  fi
fi

# --- 1. 走査：今回配るファイルを洗い出し、追加/更新を分類する（まだ書き換えない） ---
#        added_files   … 展開先に無い（新規）ファイル
#        updated_files … 既存だが内容が変わるファイル
#        （内容が同一のものはどちらにも記録しない＝出力に出さない）
#        copy_plan     … 確認後に実行するコピーの計画（「コピー元<TAB>コピー先」）
new_files=""
added_files=""
updated_files=""
copy_plan=""
for src in $SELECTED; do
  src_dir="$REPO_ROOT/$src"
  [ -d "$src_dir" ] || continue
  while IFS= read -r f; do
    base="$(basename "$f")"
    case " $EXCLUDE_BASENAMES " in *" $base "*) continue ;; esac  # 除外対象はスキップ
    rel="${f#"$src_dir"/}"            # ソース内の相対パス
    dest_rel=".$src/$rel"            # 展開先相対パス（.claude/... など）
    dest_path="$TARGET/$dest_rel"
    if [ ! -e "$dest_path" ]; then
      added_files="$added_files$dest_rel
"
    elif ! cmp -s "$f" "$dest_path"; then
      updated_files="$updated_files$dest_rel
"
    fi
    copy_plan="$copy_plan$f	$dest_path
"
    new_files="$new_files$dest_rel
"
  done < <(find "$src_dir" -type f)
done

# --- 2. 旧マニフェストと突き合わせ、削除対象を洗い出す（まだ消さない） ---
#        （マニフェストに無い＝プロジェクト固有のファイルは対象外）
#        判定は選択ツール配下の行だけに限定する。非選択ツールの行は今回配っていない
#        だけで消えたわけではないので、削除せず kept_files としてマニフェストへ持ち越す。
deleted_files=""
kept_files=""
if [ -f "$MANIFEST" ]; then
  while IFS= read -r old; do
    [ -z "$old" ] && continue
    # 選択ツール配下の行か判定（.claude/... の先頭要素を SELECTED と突き合わせる）
    old_tool="${old%%/*}"      # ".claude" など
    old_tool="${old_tool#.}"   # "claude"
    is_selected=0
    for src in $SELECTED; do
      if [ "$old_tool" = "$src" ]; then is_selected=1; break; fi
    done
    if [ "$is_selected" -eq 0 ]; then
      kept_files="$kept_files$old
"
      continue
    fi
    # 今回の配布対象に含まれているか確認
    if ! printf '%s' "$new_files" | grep -qxF "$old"; then
      deleted_files="$deleted_files$old
"
    fi
  done < "$MANIFEST"
fi

# --- 3. サマリー表示（適用前。ここで見せた内容がそのまま確認の対象になる） ---

# リスト整形/集計ヘルパ
_lines() { printf '%s' "$1" | grep -v '^$'; }              # 空行を除いた行を出す
_cnt()   { _lines "$1" | grep -c "^\\.$2/" || true; }      # $2=ツール名 の件数

# ツールを絞ったときだけ対象を明示する（全展開時は従来どおりの見た目を保つ）
scope=""
if [ "$SELECTED" != "$SOURCES" ]; then
  scope=" ($(printf '%s' "$SELECTED" | sed 's/ /, /g'))"
fi
printf '\n%sagent-setup%s%s%s%s → %s\n\n' "$C_BOLD" "$C_RST" "$C_DIM" "$scope" "$C_RST" "$TARGET"

# ツール別サマリー（変更のあったツールのみ）
any_change=0
for src in $SELECTED; do
  a="$(_cnt "$added_files" "$src")"
  u="$(_cnt "$updated_files" "$src")"
  d="$(_cnt "$deleted_files" "$src")"
  [ "$a" -eq 0 ] && [ "$u" -eq 0 ] && [ "$d" -eq 0 ] && continue
  any_change=1
  printf '  %-10s' ".$src"
  [ "$a" -gt 0 ] && printf ' %s+ %s%s' "$C_ADD" "$a" "$C_RST"
  [ "$u" -gt 0 ] && printf ' %s~ %s%s' "$C_UPD" "$u" "$C_RST"
  [ "$d" -gt 0 ] && printf ' %s- %s%s' "$C_DEL" "$d" "$C_RST"
  printf '\n'
done

# 変更ファイル一覧（+ 追加 / ~ 更新 / - 削除）。各グループ内はパスでソート
if [ "$any_change" -eq 1 ]; then
  printf '\n'
  # 各グループは空のことがある。空だと grep -v が非0で pipefail+set -e に引っかかるため || true で吸収する。
  _lines "$added_files"   | LC_ALL=C sort | while IFS= read -r p; do printf '  %s+%s %s\n' "$C_ADD" "$C_RST" "$p"; done || true
  _lines "$updated_files" | LC_ALL=C sort | while IFS= read -r p; do printf '  %s~%s %s\n' "$C_UPD" "$C_RST" "$p"; done || true
  _lines "$deleted_files" | LC_ALL=C sort | while IFS= read -r p; do printf '  %s-%s %s\n' "$C_DEL" "$C_RST" "$p"; done || true
fi

# --- 4. 確認 ---
#        既存の .<tool> が1つでもあり、かつ実際に変更があるときだけ尋ねる。
#        全ツール新規なら壊す既存物が無いので無言、変更ゼロなら尋ねる対象が無い。
has_existing=0
for src in $SELECTED; do
  if [ -d "$TARGET/.$src" ]; then has_existing=1; fi
done

if [ "$YES" -eq 0 ] && [ "$has_existing" -eq 1 ] && [ "$any_change" -eq 1 ]; then
  if [ ! -t 0 ]; then
    printf '\n%sエラー: 既存の展開先があるため確認が必要ですが、標準入力が端末ではありません。%s\n' "$C_DEL" "$C_RST" >&2
    echo "       確認を省略して展開するには -y を付けてください。" >&2
    exit 1
  fi
  printf '\n以上の内容で展開します。よろしいですか? [y/N]: '
  read -r reply || reply=""   # EOF でも set -e で落とさない
  case "$reply" in
    [yY]|[yY][eE][sS]) ;;
    *) printf '中止しました。\n'; exit 1 ;;
  esac
fi

# --- 5. 適用：コピー → 削除 → マニフェスト書き出し → 空ディレクトリ掃除 ---
printf '%s' "$copy_plan" | while IFS=$'\t' read -r from to; do
  [ -z "$from" ] && continue
  mkdir -p "$(dirname "$to")"
  # 展開先に symlink が置かれていると cp はリンク先の実体へ書き込んでしまい、
  # 展開先ツリー外のファイルを上書きしうる。先に unlink してから新規作成する
  # （rm -f は symlink 自体を消し、リンク先には触らない。POSIX 範囲で移植性あり）。
  rm -f "$to"
  cp "$from" "$to"
done

_lines "$deleted_files" | while IFS= read -r old; do rm -f "$TARGET/$old"; done || true

# 今回配ったファイル + 非選択ツールの持ち越し分をマージする（ソート・重複排除）。
printf '%s%s' "$new_files" "$kept_files" | grep -v '^$' | LC_ALL=C sort -u > "$MANIFEST" || true

for src in $SELECTED; do
  d="$TARGET/.$src"
  [ -d "$d" ] && find "$d" -type d -empty -delete 2>/dev/null || true
done

# --- 6. 完了行 ---
count="$(grep -c . "$MANIFEST" 2>/dev/null || echo 0)"
printf '\n'
if [ "$any_change" -eq 0 ]; then
  printf '%s✓%s %s files managed  %s·  変更なし%s\n' "$C_ADD" "$C_RST" "$count" "$C_DIM" "$C_RST"
else
  printf '%s✓%s %s files managed  %s·%s %s\n' "$C_ADD" "$C_RST" "$count" "$C_DIM" "$C_RST" "$MANIFEST"
fi
