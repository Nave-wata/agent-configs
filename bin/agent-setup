#!/usr/bin/env bash
#
# agent-setup — agent-configs のエージェント設定を対象プロジェクトへ展開する。
#
#   使い方:
#     agent-setup            # カレントディレクトリへ展開
#     agent-setup <path>     # 指定ディレクトリへ展開
#
#   方式:
#     リポジトリ内の各ソースディレクトリ（claude/ codex/ opencode/）を、
#     対象プロジェクトの .claude/ .codex/ .opencode/ へコピーする。
#     スクリプト自身の位置からリポルートを解決するため、リポをどこに
#     置いても動作する（ディレクトリ非依存）。
#
#   更新（マニフェスト方式）:
#     展開したファイル一覧を対象プロジェクトの .agent-configs-manifest に記録する。
#     再実行時は「前回配ったが今回ソースに無いファイル」だけを削除し、
#     マニフェストに無いファイル（プロジェクト固有のファイル）は一切触らない。
#
#   出力:
#     再実行のたびに何が変わったかを可視化する。ファイルごとに
#     追加(+) / 更新(~) / 削除(-) を判定し、ツール別（.claude/.codex/.opencode）に
#     集計したうえで変更ファイルを一覧表示する。無変更のものは表示しない。
#     色は stdout が端末のときだけ付与し、パイプ/リダイレクト時や NO_COLOR
#     設定時は自動で無色にフォールバックする。
#
set -euo pipefail

# --- リポルート（スクリプト自身の位置基準。symlink 経由で呼ばれても実体を解決） ---
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in
    /*) ;;                      # 絶対パスはそのまま
    *) SOURCE="$DIR/$SOURCE" ;; # 相対 symlink は元ディレクトリ基準で解決
  esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# --- 展開先（引数 or カレント） ---
TARGET_ARG="${1:-$PWD}"
if [ ! -d "$TARGET_ARG" ]; then
  echo "エラー: 展開先ディレクトリが存在しません: $TARGET_ARG" >&2
  exit 1
fi
TARGET="$(cd "$TARGET_ARG" && pwd)"

MANIFEST="$TARGET/.agent-configs-manifest"

# 配布するソースディレクトリ（トップレベル名）。それぞれ .<name> へ展開する。
SOURCES="claude codex opencode"

# 配布から除外するファイル名（basename 一致）。
#   settings.json … プロジェクトごとに管理される（プロジェクトの git に入る）ため配布しない
#   .gitignore    … 旧・独立リポ時代の名残。展開先の git 管理に干渉させない
# settings.local.json は個人共通のローカル設定として配布する（除外しない）。
EXCLUDE_BASENAMES="settings.json .gitignore"

# --- 色（stdout が端末で、NO_COLOR 未設定のときだけ付与） ---
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_ADD=$'\033[32m'; C_UPD=$'\033[33m'; C_DEL=$'\033[31m'
  C_DIM=$'\033[2m';  C_BOLD=$'\033[1m'; C_RST=$'\033[0m'
else
  C_ADD=''; C_UPD=''; C_DEL=''; C_DIM=''; C_BOLD=''; C_RST=''
fi

# 配布元が1つも見つからない場合は無言終了せず明示的に失敗する
# （symlink 解決ミスなどでリポルートを取り違えていないかの早期検知）。
_found_src=0
for src in $SOURCES; do
  [ -d "$REPO_ROOT/$src" ] && _found_src=1
done
if [ "$_found_src" -eq 0 ]; then
  echo "エラー: 配布元が見つかりません（REPO_ROOT=$REPO_ROOT）。" >&2
  echo "       agent-setup の配置、またはリポルートの解決を確認してください。" >&2
  exit 1
fi

# --- 1. 今回配布するファイルをコピーしつつ、追加/更新を分類する ---
#        added_files   … 展開先に無かった（新規）ファイル
#        updated_files … 既存だが内容が変わったファイル
#        （内容が同一のものはどちらにも記録しない＝出力に出さない）
new_files=""
added_files=""
updated_files=""
for src in $SOURCES; do
  src_dir="$REPO_ROOT/$src"
  [ -d "$src_dir" ] || continue
  dest_dir="$TARGET/.$src"
  while IFS= read -r f; do
    base="$(basename "$f")"
    case " $EXCLUDE_BASENAMES " in *" $base "*) continue ;; esac  # 除外対象はスキップ
    rel="${f#"$src_dir"/}"            # ソース内の相対パス
    dest_rel=".$src/$rel"            # 展開先相対パス（.claude/... など）
    dest_path="$dest_dir/$rel"
    if [ ! -e "$dest_path" ]; then
      added_files="$added_files$dest_rel
"
    elif ! cmp -s "$f" "$dest_path"; then
      updated_files="$updated_files$dest_rel
"
    fi
    mkdir -p "$dest_dir/$(dirname "$rel")"
    cp "$f" "$dest_path"
    new_files="$new_files$dest_rel
"
  done < <(find "$src_dir" -type f)
done

# --- 2. 旧マニフェストにあって今回配らなかったファイルを削除（削除分を記録） ---
#        （マニフェストに無い＝プロジェクト固有のファイルは対象外） ---
deleted_files=""
if [ -f "$MANIFEST" ]; then
  while IFS= read -r old; do
    [ -z "$old" ] && continue
    # 今回の配布対象に含まれているか確認
    if ! printf '%s' "$new_files" | grep -qxF "$old"; then
      rm -f "$TARGET/$old"
      deleted_files="$deleted_files$old
"
    fi
  done < "$MANIFEST"
fi

# --- 3. 新マニフェストを書き出し（ソート・重複排除） ---
printf '%s' "$new_files" | grep -v '^$' | LC_ALL=C sort -u > "$MANIFEST" || true

# --- 4. 配布先の空ディレクトリを掃除 ---
for src in $SOURCES; do
  d="$TARGET/.$src"
  [ -d "$d" ] && find "$d" -type d -empty -delete 2>/dev/null || true
done

# --- 5. サマリー出力 ---
count="$(grep -c . "$MANIFEST" 2>/dev/null || echo 0)"

# リスト整形/集計ヘルパ
_lines() { printf '%s' "$1" | grep -v '^$'; }              # 空行を除いた行を出す
_cnt()   { _lines "$1" | grep -c "^\\.$2/" || true; }      # $2=ツール名 の件数

printf '\n%sagent-setup%s → %s\n\n' "$C_BOLD" "$C_RST" "$TARGET"

# ツール別サマリー（変更のあったツールのみ）
any_change=0
for src in $SOURCES; do
  a="$(_cnt "$added_files" "$src")"
  u="$(_cnt "$updated_files" "$src")"
  d="$(_cnt "$deleted_files" "$src")"
  [ "$a" -eq 0 ] && [ "$u" -eq 0 ] && [ "$d" -eq 0 ] && continue
  any_change=1
  printf '  %-10s' ".$src"
  [ "$a" -gt 0 ] && printf ' %s+ %s%s' "$C_ADD" "$a" "$C_RST"
  [ "$u" -gt 0 ] && printf ' %s~ %s%s' "$C_UPD" "$u" "$C_RST"
  [ "$d" -gt 0 ] && printf ' %s- %s%s' "$C_DEL" "$d" "$C_RST"
  printf '\n'
done

# 変更ファイル一覧（+ 追加 / ~ 更新 / - 削除）。各グループ内はパスでソート
if [ "$any_change" -eq 1 ]; then
  printf '\n'
  # 各グループは空のことがある。空だと grep -v が非0で pipefail+set -e に引っかかるため || true で吸収する。
  _lines "$added_files"   | LC_ALL=C sort | while IFS= read -r p; do printf '  %s+%s %s\n' "$C_ADD" "$C_RST" "$p"; done || true
  _lines "$updated_files" | LC_ALL=C sort | while IFS= read -r p; do printf '  %s~%s %s\n' "$C_UPD" "$C_RST" "$p"; done || true
  _lines "$deleted_files" | LC_ALL=C sort | while IFS= read -r p; do printf '  %s-%s %s\n' "$C_DEL" "$C_RST" "$p"; done || true
fi

printf '\n'
if [ "$any_change" -eq 0 ]; then
  printf '%s✓%s %s files managed  %s·  変更なし%s\n' "$C_ADD" "$C_RST" "$count" "$C_DIM" "$C_RST"
else
  printf '%s✓%s %s files managed  %s·%s %s\n' "$C_ADD" "$C_RST" "$count" "$C_DIM" "$C_RST" "$MANIFEST"
fi
