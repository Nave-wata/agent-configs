{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "ENABLE_EXPERIMENTAL_MCP_CLI": "false",
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "ANTHROPIC_MODEL": "claude-opus-4-8"
  },
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(git config:*)",
      "Bash(brew install:*)",
      "Bash(chmod 777:*)",
      "Bash(:*aws:*)",
      "Bash(:*cdk deploy:*)",
      "Bash(:*cdk destroy:*)",
      "Bash(claude:*)",
      "Bash(codex:*)",
      "Bash(gemini:*)",
      "Read(id_rsa*)",
      "Read(id_ed25519*)",
      "Read(*.key)",
      "Read(*.pem)",
      "Write(.env*)",
      "Write(id_rsa*)",
      "Write(*.key)",
      "Write(*.pem)"
    ],
    "defaultMode": "auto"
  },
  "disabledMcpjsonServers": [
    "laravel-boost"
  ],
  "statusLine": {
    "type": "command",
    "command": ".claude/statuslines/entry.sh"
  },
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "agentic-actions-auditor@trailofbits": true,
    "differential-review@trailofbits": true,
    "insecure-defaults@trailofbits": true,
    "sharp-edges@trailofbits": true,
    "static-analysis@trailofbits": true,
    "supply-chain-risk-auditor@trailofbits": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      },
      "autoUpdate": true
    }
  },
  "viewMode": "focus",
  "language": "Japanese",
  "advisorModel": "fable",
  "showThinkingSummaries": true,
  "theme": "dark",
  "autoCompactEnabled": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "effort": "high",
  "feedbackSurveyState": {
    "lastShownTime": 1759987200753
  }
}
