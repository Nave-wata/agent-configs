{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".claude/CLAUDE.md"
  ],
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "sudo*": "deny",
      "git config*": "deny",
      "brew install*": "deny",
      "chmod 777*": "deny",
      "aws*": "deny",
      "cdk deploy*": "deny",
      "cdk destroy*": "deny",
      "claude*": "deny",
      "codex*": "deny",
      "gemini*": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "id_rsa*": "deny",
      "id_ed25519*": "deny",
      "*.key": "deny",
      "*.pem": "deny"
    },
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "id_rsa*": "deny",
      "id_ed25519*": "deny",
      "*.key": "deny",
      "*.pem": "deny"
    }
  },
  "model": "ollama/opencode:latest",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://host.docker.internal:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "opencode:latest": {
          "name": "opencode:latest"
        }
      }
    }
  }
}
